{
  "name": "instant-demo-plumber",
  "description": "Stand up a complete plumber demo site in one run: branded home page (hero + trust badges + services grid + service-area + emergency CTA), Services/About/Contact pages, nav menu, static front page, SEO meta and LocalBusiness schema. Inputs: business, city, phone (required); tagline, email (optional). Screenshot the front page and pitch.",
  "inputs": {
    "business": { "type": "string", "required": true },
    "city":     { "type": "string", "required": true },
    "phone":    { "type": "string", "required": true },
    "tagline":  { "type": "string", "required": false },
    "email":    { "type": "string", "required": false }
  },
  "steps": [
    { "ability": "option-set", "params": { "name": "blogname", "value": "{input.business}", "confirm": true } },
    { "ability": "option-set", "params": { "name": "blogdescription", "value": "{input.tagline}", "confirm": true } },

    { "ability": "create-post", "save_as": "home", "params": { "post_type": "page", "status": "publish", "title": "Home", "slug": "demo-home", "content": "<div style='font-family:system-ui,-apple-system,Segoe UI,sans-serif;color:#1d2b3a'><section style='background:linear-gradient(135deg,#0e3a66,#1673c8);color:#fff;border-radius:18px;padding:64px 36px;text-align:center'><p style='margin:0 0 10px;letter-spacing:.14em;text-transform:uppercase;font-size:13px;color:#ffd88a'>Licensed &amp; insured &middot; 24/7 emergency service</p><h1 style='margin:0 0 14px;font-size:44px;line-height:1.1'>{input.business}</h1><p style='margin:0 auto 28px;max-width:560px;font-size:19px;color:#dbeafe'>{input.tagline} Fast, tidy, guaranteed plumbing across {input.city}.</p><p style='margin:0'><a href='tel:{input.phone}' style='display:inline-block;background:#f5a623;color:#132433;font-weight:700;padding:15px 30px;border-radius:10px;text-decoration:none;font-size:17px'>&#128222; Call {input.phone}</a> <a href='/demo-contact/' style='display:inline-block;border:2px solid #9cc4ee;color:#fff;font-weight:600;padding:13px 26px;border-radius:10px;text-decoration:none;font-size:17px;margin-left:10px'>Get a free quote</a></p></section><section style='display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:14px;margin:26px 0'><div style='background:#f4f8fc;border:1px solid #dbe7f3;border-radius:12px;padding:18px;text-align:center'><strong>&#9989; Licensed &amp; insured</strong></div><div style='background:#f4f8fc;border:1px solid #dbe7f3;border-radius:12px;padding:18px;text-align:center'><strong>&#9889; Same-day service</strong></div><div style='background:#f4f8fc;border:1px solid #dbe7f3;border-radius:12px;padding:18px;text-align:center'><strong>&#128337; 24/7 emergency</strong></div><div style='background:#f4f8fc;border:1px solid #dbe7f3;border-radius:12px;padding:18px;text-align:center'><strong>&#11088; 5-star rated locally</strong></div></section><section style='margin:38px 0'><h2 style='text-align:center;font-size:32px;margin:0 0 8px'>What we fix</h2><p style='text-align:center;color:#5b6b7d;margin:0 0 26px'>No job too small — upfront pricing before we start.</p><div style='display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:16px'><div style='border:1px solid #dbe7f3;border-radius:14px;padding:22px'><div style='font-size:30px'>&#128167;</div><h3 style='margin:10px 0 6px'>Leak detection &amp; repair</h3><p style='margin:0;color:#5b6b7d'>Dripping taps to hidden pipe leaks — found fast, fixed for good.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:22px'><div style='font-size:30px'>&#127754;</div><h3 style='margin:10px 0 6px'>Blocked drains</h3><p style='margin:0;color:#5b6b7d'>High-pressure jetting and camera inspection for stubborn blockages.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:22px'><div style='font-size:30px'>&#128293;</div><h3 style='margin:10px 0 6px'>Water heaters</h3><p style='margin:0;color:#5b6b7d'>Repair, replacement and installation — gas and electric.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:22px'><div style='font-size:30px'>&#128703;</div><h3 style='margin:10px 0 6px'>Bathroom &amp; kitchen</h3><p style='margin:0;color:#5b6b7d'>Full fit-outs, fixture swaps and renovation plumbing.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:22px'><div style='font-size:30px'>&#128295;</div><h3 style='margin:10px 0 6px'>Pipe replacement</h3><p style='margin:0;color:#5b6b7d'>Old, noisy or corroded pipes replaced with minimal disruption.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:22px'><div style='font-size:30px'>&#128680;</div><h3 style='margin:10px 0 6px'>Emergency call-outs</h3><p style='margin:0;color:#5b6b7d'>Burst pipe at 3am? We answer, we come, we fix.</p></div></div></section><section style='background:#f4f8fc;border-radius:14px;padding:26px;text-align:center;margin:30px 0'><h2 style='margin:0 0 6px'>Serving {input.city} &amp; surrounding areas</h2><p style='margin:0;color:#5b6b7d'>Local plumbers, local response times — usually on-site within the hour.</p></section><section style='background:#f5a623;border-radius:14px;padding:30px;text-align:center;margin:30px 0'><h2 style='margin:0 0 8px;color:#132433'>Burst pipe? Flooding?</h2><p style='margin:0 0 16px;color:#3d3421'>Don&#8217;t wait — our emergency line is open 24/7.</p><a href='tel:{input.phone}' style='display:inline-block;background:#132433;color:#fff;font-weight:700;padding:14px 30px;border-radius:10px;text-decoration:none;font-size:17px'>&#128222; {input.phone}</a></section></div>" } },

    { "ability": "create-post", "save_as": "services", "params": { "post_type": "page", "status": "publish", "title": "Services", "slug": "demo-services", "content": "<div style='font-family:system-ui,-apple-system,Segoe UI,sans-serif;color:#1d2b3a'><h1 style='font-size:38px;margin:0 0 8px'>Plumbing services in {input.city}</h1><p style='color:#5b6b7d;font-size:18px;margin:0 0 30px'>Upfront fixed quotes, tidy workmanship, and a 12-month guarantee on every job.</p><div style='display:grid;gap:16px'><div style='border:1px solid #dbe7f3;border-radius:14px;padding:24px'><h2 style='margin:0 0 6px'>&#128167; Leak detection &amp; repair</h2><p style='margin:0;color:#5b6b7d'>Acoustic and thermal leak detection finds the problem without tearing your walls open. Taps, toilets, mains and concealed pipework.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:24px'><h2 style='margin:0 0 6px'>&#127754; Blocked drains &amp; sewers</h2><p style='margin:0;color:#5b6b7d'>CCTV camera inspection, high-pressure water jetting and root cutting. We show you the before/after footage.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:24px'><h2 style='margin:0 0 6px'>&#128293; Hot water systems</h2><p style='margin:0;color:#5b6b7d'>Same-day repair or replacement of gas and electric water heaters — supplied, installed and old unit taken away.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:24px'><h2 style='margin:0 0 6px'>&#128703; Bathroom &amp; kitchen plumbing</h2><p style='margin:0;color:#5b6b7d'>Renovation rough-ins, fixture installation, dishwasher and washing-machine connections.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:24px'><h2 style='margin:0 0 6px'>&#128295; Repiping &amp; pipe replacement</h2><p style='margin:0;color:#5b6b7d'>Corroded galvanised or noisy pipes replaced with modern PEX/copper, with minimal wall access.</p></div><div style='border:1px solid #dbe7f3;border-radius:14px;padding:24px'><h2 style='margin:0 0 6px'>&#128680; 24/7 emergency plumbing</h2><p style='margin:0;color:#5b6b7d'>Burst pipes, gas leaks, flooding, no hot water — a real plumber answers, day or night.</p></div></div><p style='text-align:center;margin:34px 0 0'><a href='tel:{input.phone}' style='display:inline-block;background:#f5a623;color:#132433;font-weight:700;padding:15px 30px;border-radius:10px;text-decoration:none;font-size:17px'>&#128222; Call {input.phone} for a free quote</a></p></div>" } },

    { "ability": "create-post", "save_as": "about", "params": { "post_type": "page", "status": "publish", "title": "About", "slug": "demo-about", "content": "<div style='font-family:system-ui,-apple-system,Segoe UI,sans-serif;color:#1d2b3a;max-width:760px'><h1 style='font-size:38px;margin:0 0 8px'>About {input.business}</h1><p style='color:#5b6b7d;font-size:18px'>We&#8217;re a local, family-run plumbing team serving {input.city} and the surrounding suburbs. From dripping taps to full bathroom fit-outs, we turn up on time, quote before we start, and leave the place cleaner than we found it.</p><h2>Why locals choose us</h2><ul style='color:#3d4c5c;line-height:1.9'><li><strong>Upfront pricing</strong> — fixed quote before any work begins, no surprises.</li><li><strong>Licensed &amp; insured</strong> — fully certified plumbers and gas fitters.</li><li><strong>12-month guarantee</strong> — every repair and installation is covered.</li><li><strong>Genuine 24/7</strong> — a plumber answers the emergency line, not a call centre.</li><li><strong>Respect for your home</strong> — boot covers, drop sheets, and a tidy-up after every job.</li></ul><p style='margin-top:26px'><a href='tel:{input.phone}' style='display:inline-block;background:#1673c8;color:#fff;font-weight:700;padding:13px 26px;border-radius:10px;text-decoration:none'>&#128222; Talk to us — {input.phone}</a></p></div>" } },

    { "ability": "create-post", "save_as": "contact", "params": { "post_type": "page", "status": "publish", "title": "Contact", "slug": "demo-contact", "content": "<div style='font-family:system-ui,-apple-system,Segoe UI,sans-serif;color:#1d2b3a;max-width:760px'><h1 style='font-size:38px;margin:0 0 8px'>Get a fast, free quote</h1><p style='color:#5b6b7d;font-size:18px'>Tell us what&#8217;s wrong and we&#8217;ll tell you what it costs — usually within minutes.</p><div style='display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin:26px 0'><div style='background:#f4f8fc;border:1px solid #dbe7f3;border-radius:14px;padding:24px;text-align:center'><div style='font-size:28px'>&#128222;</div><h3 style='margin:8px 0 4px'>Call or text</h3><a href='tel:{input.phone}' style='color:#1673c8;font-weight:700;font-size:19px;text-decoration:none'>{input.phone}</a><p style='margin:6px 0 0;color:#5b6b7d;font-size:14px'>24/7 for emergencies</p></div><div style='background:#f4f8fc;border:1px solid #dbe7f3;border-radius:14px;padding:24px;text-align:center'><div style='font-size:28px'>&#9993;&#65039;</div><h3 style='margin:8px 0 4px'>Email</h3><a href='mailto:{input.email}' style='color:#1673c8;font-weight:700;text-decoration:none'>{input.email}</a><p style='margin:6px 0 0;color:#5b6b7d;font-size:14px'>Photos of the problem help!</p></div><div style='background:#f4f8fc;border:1px solid #dbe7f3;border-radius:14px;padding:24px;text-align:center'><div style='font-size:28px'>&#128205;</div><h3 style='margin:8px 0 4px'>Service area</h3><p style='margin:0;color:#3d4c5c;font-weight:600'>{input.city} &amp; surrounds</p><p style='margin:6px 0 0;color:#5b6b7d;font-size:14px'>On-site within the hour</p></div></div><section style='background:#f5a623;border-radius:14px;padding:26px;text-align:center'><h2 style='margin:0 0 8px;color:#132433'>Plumbing emergency right now?</h2><a href='tel:{input.phone}' style='display:inline-block;background:#132433;color:#fff;font-weight:700;padding:14px 30px;border-radius:10px;text-decoration:none;font-size:17px'>&#128222; Call {input.phone}</a></section></div>" } },

    { "ability": "manage-menu", "save_as": "menu", "params": { "action": "create-menu", "name": "Demo Main Menu", "confirm": true } },
    { "ability": "manage-menu", "params": { "action": "add-item", "menu": "{steps.menu.menu_id}", "item": { "title": "Home", "object_id": "{steps.home.post_id}", "object_type": "post", "object": "page", "position": 1 } } },
    { "ability": "manage-menu", "params": { "action": "add-item", "menu": "{steps.menu.menu_id}", "item": { "title": "Services", "object_id": "{steps.services.post_id}", "object_type": "post", "object": "page", "position": 2 } } },
    { "ability": "manage-menu", "params": { "action": "add-item", "menu": "{steps.menu.menu_id}", "item": { "title": "About", "object_id": "{steps.about.post_id}", "object_type": "post", "object": "page", "position": 3 } } },
    { "ability": "manage-menu", "params": { "action": "add-item", "menu": "{steps.menu.menu_id}", "item": { "title": "Contact", "object_id": "{steps.contact.post_id}", "object_type": "post", "object": "page", "position": 4 } } },
    { "ability": "manage-menu", "continue_on_error": true, "params": { "action": "assign-location", "menu": "{steps.menu.menu_id}", "location": "menu-1", "confirm": true } },

    { "ability": "option-set", "params": { "name": "show_on_front", "value": "page", "confirm": true } },
    { "ability": "option-set", "params": { "name": "page_on_front", "value": "{steps.home.post_id}", "confirm": true } },

    { "ability": "seo-set-meta", "continue_on_error": true, "params": { "post_id": "{steps.home.post_id}", "title": "Plumber in {input.city} — {input.business} | 24/7 Emergency", "description": "Licensed local plumbers in {input.city}: leak repair, blocked drains, hot water, bathrooms and 24/7 emergency call-outs. Upfront pricing — call {input.phone}." } },
    { "ability": "seo-manage-local-business", "continue_on_error": true, "params": { "action": "set", "name": "{input.business}", "type": "Plumber", "phone": "{input.phone}", "city": "{input.city}" } },
    { "ability": "custom-css", "continue_on_error": true, "params": { "action": "append", "css": "body.home .entry-title, body.home h1.wp-block-post-title { display: none; }" } },
    { "ability": "purge-cache", "continue_on_error": true, "params": {} }
  ]
}
